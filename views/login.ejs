<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login | Student Management System</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    * { font-family: 'Inter', sans-serif; }
    body {
      display: flex;
      align-items: center;
      justify-content: center;
      height: 100vh;
      margin: 0;
      background: #F4F7FE;
    }
    .login-card {
      background: #fff;
      padding: 50px 40px;
      border-radius: 24px;
      box-shadow: 0 10px 40px rgba(0,0,0,0.06);
      max-width: 420px;
      width: 100%;
    }
    .logo-box {
      width: 50px;
      height: 50px;
      background: linear-gradient(135deg, #FF9C00, #FFC048);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      font-weight: 700;
      font-size: 24px;
      margin: 0 auto 20px auto;
    }
    .login-card h3 {
      text-align: center;
      font-weight: 700;
      color: #2B3674;
      margin-bottom: 4px;
    }
    .login-card .subtext {
      text-align: center;
      color: #A3AED0;
      font-size: 14px;
      margin-bottom: 28px;
    }
    .form-control {
      background: #F8FAFC;
      border-radius: 12px;
      padding: 12px 16px;
      border: 1px solid #E2E8F0;
    }
    .form-control:focus {
      border-color: #6366F1;
      box-shadow: 0 0 0 3px rgba(99,102,241,0.15);
      background: #fff;
    }
    .btn-signin {
      background: #6366F1;
      border: none;
      border-radius: 12px;
      padding: 12px;
      width: 100%;
      color: #fff;
      font-weight: 600;
      transition: background 0.2s;
    }
    .btn-signin:hover { background: #4F46E5; color: #fff; }
    label { font-size: 14px; font-weight: 500; color: #2B3674; margin-bottom: 6px; }
  </style>
</head>
<body>
  <div class="login-card">
    <div class="logo-box">S</div>
    <h3>Welcome Back</h3>
    <p class="subtext">Student Management System</p>

    <% if (error) { %>
      <div class="alert alert-danger py-2 text-center"><%= error %></div>
    <% } %>

    <form method="POST" action="/login">
      <div class="mb-3">
        <label>Email</label>
        <input type="text" name="email" class="form-control" placeholder="admin@gmail.com" required>
      </div>
      <div class="mb-4">
        <label>Password</label>
        <input type="password" name="password" class="form-control" placeholder="••••••" required>
      </div>
      <button type="submit" class="btn-signin">Sign In</button>
    </form>
  </div>
</body>
</html>
